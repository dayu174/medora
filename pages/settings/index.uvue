<template>
  <view class="app-page safe-top">
    <view class="phone-frame settings-phone-frame">
      <AppHeader title="设置" :back="true" />
      <scroll-view class="page-scroll" scroll-y="true" :show-scrollbar="false">
        <view class="content settings-content">
          <!-- Standard sections -->
          <view v-for="section in sections" :key="section.title" class="settings-section">
            <text class="section-title settings-title">{{ section.title }}</text>
            <view class="settings-card card">
              <view v-for="item in section.items" :key="item.label">
                <SettingRow :label="item.label" :icon="item.icon" :path="item.path" :meta="item.meta" :toggle="item.toggle" @action="onRowAction" />
                <view class="divider"></view>
              </view>
            </view>
          </view>

          <!-- 智能归档 API Key -->
          <view class="settings-section">
            <text class="section-title settings-title">智能归档</text>
            <view class="api-desc">
              <text class="api-desc-text">使用阿里云百炼 API 自动整理临床笔记，仅需填入您的 API Key 即可。</text>
            </view>
            <view class="settings-card card">
              <view class="api-row">
                <text class="api-label">API Key</text>
                <input
                  class="api-input"
                  v-model="apiKey"
                  placeholder="sk-..."
                  password="true"
                  @blur="saveApiConfig"
                />
              </view>
              <view class="api-divider"></view>
              <view class="api-row">
                <text class="api-label">语音服务地址</text>
                <input
                  class="api-input"
                  v-model="voiceUploadEndpoint"
                  placeholder="https://..."
                  @blur="saveVoiceServiceConfig"
                />
              </view>
            </view>
          </view>

          <view class="settings-section">
            <text class="section-title settings-title">实验室功能</text>
            <view class="settings-card card">
              <view class="lab-row" @tap="openLaboratory('western')"><view><text class="lab-title">完整临床整理</text><text class="lab-copy">实验性工作台</text></view><text class="lab-arrow">›</text></view>
              <view class="divider"></view>
              <view class="lab-row" @tap="openLaboratory('tcm')"><view><text class="lab-title">中医辨证整理</text><text class="lab-copy">实验性工作台</text></view><text class="lab-arrow">›</text></view>
            </view>
          </view>

          <text class="logout-button" @tap="confirmLogout">退出登录</text>
          <view style="height: 24px;"></view>
        </view>
      </scroll-view>

      <!-- About Modal -->
      <view v-if="showAbout" class="modal-mask" @tap="showAbout = false">
        <view class="modal-box" @tap.stop="">
          <text class="modal-app-name">Medora</text>
          <text class="modal-version">版本 1.0.0</text>
          <view class="modal-divider"></view>
          <text class="modal-copy">专为医学生和临床医生打造的临床辅助工具</text>
          <text class="modal-copy">© 2026 Medora Team</text>
          <text class="modal-button" @tap="showAbout = false">确定</text>
        </view>
      </view>

      <BottomTabs active="profile" />
    </view>
  </view>
</template>

<script lang="uts">
import AppHeader from '../../components/AppHeader/AppHeader.uvue'
import BottomTabs from '../../components/BottomTabs/BottomTabs.uvue'
import SettingRow from '../../components/SettingRow/SettingRow.uvue'
import { settingsSections } from '../../common/medora-data.uts'

export default {
  components: { AppHeader, BottomTabs, SettingRow },
  data() {
    return {
      sections: settingsSections,
      showAbout: false,
      apiKey: '',
      voiceUploadEndpoint: ''
    }
  },
  onShow() {
    this.loadApiConfig()
  },
  methods: {
    loadApiConfig() {
      const key = uni.getStorageSync('smartArchiveApiKey')
      if (key != null && key != '') this.apiKey = key as string
      const endpoint = uni.getStorageSync('voiceUploadEndpoint')
      if (endpoint != null && endpoint != '') this.voiceUploadEndpoint = endpoint as string
    },
    saveApiConfig() {
      uni.setStorageSync('smartArchiveApiKey', this.apiKey)
      uni.showToast({ title: '配置已保存', icon: 'success' })
    },
    saveVoiceServiceConfig() {
      const endpoint = this.voiceUploadEndpoint.trim().replace(/\/$/, '')
      if (endpoint !== '' && !endpoint.startsWith('https://')) {
        uni.showToast({ title: '请使用 HTTPS 服务地址', icon: 'none' })
        return
      }
      this.voiceUploadEndpoint = endpoint
      uni.setStorageSync('voiceUploadEndpoint', endpoint)
      uni.showToast({ title: '语音服务地址已保存', icon: 'success' })
    },
    openLaboratory(kind: string) {
      const path = kind === 'tcm' ? '/pages/organize-tcm/index?sourceMode=laboratory&content=' : '/pages/organize/index?sourceMode=laboratory&content='
      uni.navigateTo({ url: path, animationType: 'fade-in', animationDuration: 280 } as any)
    },
    onRowAction(action : string) {
      if (action == 'about') {
        this.showAbout = true
      } else if (action == 'cleanCache') {
        this.cleanCache()
      }
    },
    cleanCache() {
      for (let i = 0; i < this.sections.length; i++) {
        let sec = this.sections[i]
        for (let j = 0; j < sec.items.length; j++) {
          if (sec.items[j].path == 'cleanCache') {
            sec.items[j].meta = '0 MB'
          }
        }
      }
      uni.showToast({ title: '缓存已清理', icon: 'none' })
    },
    confirmLogout() {
      uni.showModal({
        title: '退出登录',
        content: '确定要退出登录吗？',
        success: (res) => {
          if (res.confirm) {
            uni.reLaunch({ url: '/pages/home/index' })
          }
        }
      } as any)
    }
  }
}
</script>

<style scoped>
