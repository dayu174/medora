  width: 80px;
  color: #1a1c1c;
  font-size: 16px;
  line-height: 24px;
  font-weight: 700;
  flex-shrink: 0;
}
.api-input {
  flex: 1;
  height: 40px;
  color: #414847;
  font-size: 14px;
  line-height: 20px;
  padding: 0;
  margin: 0;
  border-width: 0;
  background-color: transparent;
}
.lab-row { min-height: 62px; padding: 0 16px; display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.lab-title { color: #1a1c1c; font-size: 16px; line-height: 22px; font-weight: 600; }
.lab-copy { color: #717977; font-size: 12px; line-height: 18px; margin-top: 2px; }
.lab-arrow { color: #717977; font-size: 24px; line-height: 24px; }

/* About Modal */
.settings-phone-frame { position: relative; }
.modal-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}
.modal-box {
  width: 280px;
  background-color: #ffffff;
  border-radius: 16px;
  padding: 32px 24px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.modal-app-name {
  color: #3b5e5b;
  font-size: 28px;
  line-height: 36px;
  font-weight: 700;
}
.modal-version {
  color: #717977;
  font-size: 14px;
