  margin-top: 4px;
}
.modal-divider {
  width: 100%;
  height: 1px;
  background-color: #e3e2e2;
  margin-top: 20px;
  margin-bottom: 16px;
}
.modal-copy {
  color: #414847;
  font-size: 14px;
  line-height: 20px;
  text-align: center;
}
.modal-button {
  margin-top: 20px;
  height: 44px;
  padding: 0 40px;
  border-radius: 22px;
  background-color: #3b5e5b;
  color: #ffffff;
  font-size: 16px;
  line-height: 44px;
  font-weight: 600;
  text-align: center;
}
