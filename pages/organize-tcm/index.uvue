<template>
  <view class="app-page safe-top">
    <view class="phone-frame">
      <view class="tcm-header">
        <view class="tcm-back-hit" @tap="goBack"><text class="tcm-back-icon">‹</text></view>
        <text class="tcm-title">整理记录（中医）</text>
        <text class="tcm-done" @tap="onDone">完成</text>
      </view>

      <scroll-view class="page-scroll" scroll-y="true" :show-scrollbar="false">
        <view class="tcm-main">
          <view class="original-summary" @tap="toggleOriginalRecord">
            <view class="original-summary-copy">
              <text class="original-summary-title">原始记录</text>
              <text class="original-summary-meta">{{ originalContent.length }} 字 · {{ referenceImages.length }} 项资料</text>
            </view>
            <text class="original-summary-action">{{ showOriginalRecord ? '收起' : '展开' }}</text>
          </view>

          <view v-if="showOriginalRecord" class="original-editor-card">
            <textarea class="source-editor" auto-height="true" v-model="originalContent" placeholder="补充或删减原始记录..." />
            <view class="reference-media-head">
              <text class="reference-media-title">原始资料</text>
              <text class="reference-media-add" @tap="addReferenceImages">添加</text>
            </view>
            <scroll-view v-if="referenceImages.length > 0" class="reference-media-scroll" scroll-x="true" :show-scrollbar="false">
              <view class="reference-media-row">
                <view v-for="(image, index) in referenceImages" :key="index" v-if="index < 3" class="reference-media-item" @tap="previewReferenceImage(index)">
                  <image class="reference-media-image" :src="image" mode="aspectFill"></image>
                  <text class="reference-media-delete" @tap.stop="removeReferenceImage(index)">×</text>
                </view>
                <view v-if="referenceImages.length > 3" class="reference-media-more" @tap="previewReferenceImage(3)">
                  <text class="reference-media-more-count">+{{ referenceImages.length - 3 }}</text>
                  <text class="reference-media-more-copy">查看全部</text>
                </view>
              </view>
            </scroll-view>
            <view v-else class="reference-empty" @tap="addReferenceImages"><text class="reference-empty-copy">添加原始图片以便核对</text></view>
          </view>

          <view class="analysis-head"><text class="analysis-title">辨证分析</text></view>
          <view class="analysis-card">
            <text class="field-caption">知识标题</text>
            <input class="record-title-input" v-model="recordTitle" placeholder="输入简明标题..." />
            <text class="field-caption analysis-caption">辨证结论与证候依据</text>
            <textarea class="analysis-textarea" auto-height="true" v-model="patternAnalysis" placeholder="录入辨证结论、病机与证候依据..." />
          </view>

          <view class="four-diagnosis-card">
            <text class="field-caption">四诊摘要</text>
            <view class="inspection-row">
              <view v-for="item in inspections" :key="item" class="inspection-pill" :class="selectedInspection === item ? 'inspection-pill-active' : ''" @tap="selectedInspection = item">
                <text class="inspection-text" :class="selectedInspection === item ? 'inspection-text-active' : ''">{{ item }}</text>
              </view>
            </view>
            <textarea class="four-diagnosis-textarea" auto-height="true" v-model="tonguePulse" placeholder="记录舌象、脉象或四诊观察..." />
          </view>

          <view class="treatment-card">
            <text class="treatment-label">治则治法</text>
            <textarea class="treatment-textarea" auto-height="true" v-model="treatmentPrinciples" placeholder="录入治则治法..." />
          </view>

          <view class="formula-summary-card" @tap="toggleFormulaStructure">
            <view class="formula-summary-head"><text class="formula-summary-title">方药结构</text><text class="formula-summary-action">{{ showFormulaStructure ? '收起' : '展开' }}</text></view>
            <text class="formula-summary-copy">{{ bigFormulas.length }} 个大方 · {{ smallFormulaCount() }} 个小方 · {{ formulaMedicineCount() }} 味药 · {{ sharedMedicineCount() }} 处共用</text>
          </view>

          <view v-if="showFormulaStructure" class="formula-structure">
            <view class="shared-note"><text class="shared-note-label">共用药物</text><text class="shared-note-copy">暖色标签表示该药在两个或更多小方中出现</text></view>
            <view v-for="(bigFormula, bigIndex) in bigFormulas" :key="bigIndex" class="big-formula-card">
              <view class="big-formula-head">
                <input class="big-formula-name" v-model="bigFormula.name" placeholder="大方名称" />
                <text class="big-formula-delete" @tap="removeBigFormula(bigIndex)">×</text>
              </view>
              <textarea class="big-formula-note" auto-height="true" v-model="bigFormula.note" placeholder="合方说明或使用方向..." />
              <view v-for="(smallFormula, smallIndex) in bigFormula.smallFormulas" :key="smallIndex" class="small-formula-card">
                <view class="small-formula-head">
                  <input class="small-formula-name" v-model="smallFormula.name" placeholder="小方名称" />
                  <text class="small-formula-delete" @tap="removeSmallFormula(bigIndex, smallIndex)">×</text>
                </view>
                <input class="small-formula-role" v-model="smallFormula.role" placeholder="小方作用，例如：基础方 · 健脾益气" />
                <view class="formula-medicine-row" v-for="(medicine, medicineIndex) in smallFormula.medicines" :key="medicineIndex">
                  <view class="medicine-name-wrap" :class="isSharedMedicine(medicine.name) ? 'medicine-name-wrap-shared' : ''">
                    <input class="medicine-name-input" v-model="medicine.name" placeholder="药味" />
                    <text v-if="isSharedMedicine(medicine.name)" class="medicine-shared-mark">共用</text>
                  </view>
                  <input class="medicine-dose-input" v-model="medicine.dose" placeholder="剂量/待核实" />
                  <text class="medicine-remove" @tap="removeMedicine(bigIndex, smallIndex, medicineIndex)">×</text>
                </view>
                <text class="add-medicine" @tap="addMedicine(bigIndex, smallIndex)">+ 添加药味</text>
              </view>
              <view class="add-small-formula" @tap="addSmallFormula(bigIndex)"><text class="add-small-formula-text">+ 添加小方</text></view>
            </view>
            <view class="add-big-formula" @tap="addBigFormula"><text class="add-big-formula-text">+ 添加大方</text></view>
            <view class="formula-total-card"><text class="formula-total-label">大方合方 · {{ formulaMedicineCount() }} 味药</text><text class="formula-total-copy">重复药物已标记，请在编辑状态核对名称与剂量。</text></view>
          </view>

          <view class="tag-section">
            <text class="field-caption">标签</text>
            <view class="tag-row"><view v-for="(tag, index) in tags" :key="index" class="tag-pill"><text class="tag-text">{{ tag }}</text><text class="tag-remove" @tap="removeTag(index)">×</text></view></view>
            <view class="tag-entry-row"><input class="tag-input" v-model="newTag" placeholder="添加标签..." /><text class="tag-add" @tap="addTag">添加</text></view>
          </view>
          <view v-if="missingFields.length > 0" class="notice-card"><text class="notice-title">待补充或待核实</text><text class="notice-text">{{ missingFields.join('、') }}</text></view>
          <view class="tcm-bottom-space"></view>
        </view>
      </scroll-view>
    </view>
  </view>
</template>

<script lang="uts">
interface FormulaMedicine { name: string, dose: string }
interface SmallFormula { name: string, role: string, medicines: FormulaMedicine[] }
interface BigFormula { name: string, note: string, smallFormulas: SmallFormula[] }

export default {
  data() {
    return {
      draftIndex: -1,
      sourceMode: 'draft',
      archiveKey: '',
      originalContent: '',
      referenceImages: [] as string[],
      showOriginalRecord: false,
      recordTitle: '',
      selectedInspection: '望诊',
      inspections: ['望诊', '闻诊', '问诊', '切诊'],
      tonguePulse: '',
      patternAnalysis: '',
      treatmentPrinciples: '',
      bigFormulas: [] as BigFormula[],
      showFormulaStructure: false,
      tags: [] as string[],
      newTag: '',
      missingFields: [] as string[]
    }
  },
  onLoad(options: any) {
    this.draftIndex = options != null && options.draftIndex != null ? parseInt(options.draftIndex) : -1
    this.sourceMode = options != null && options.sourceMode != null ? options.sourceMode as string : 'draft'
    this.archiveKey = options != null && options.archiveKey != null ? options.archiveKey as string : ''
    const stored = this.archiveKey !== '' ? uni.getStorageSync('archivePayload_' + this.archiveKey) as any : null
    if (stored != null) {
      this.originalContent = stored.sourceContent != null ? stored.sourceContent as string : ''
      this.referenceImages = Array.isArray(stored.images) ? stored.images : []
      const tcm = stored.payload != null && stored.payload.tcm != null ? stored.payload.tcm : {}
      this.tonguePulse = tcm.tonguePulse != null ? tcm.tonguePulse as string : ''
      this.patternAnalysis = tcm.patternAnalysis != null ? tcm.patternAnalysis as string : ''
      this.treatmentPrinciples = tcm.treatmentPrinciples != null ? tcm.treatmentPrinciples as string : ''
      this.tags = Array.isArray(tcm.tags) ? tcm.tags : []
      this.missingFields = Array.isArray(tcm.missingFields) ? tcm.missingFields : []
      if (Array.isArray(tcm.herbs) && tcm.herbs.length > 0) {
        this.bigFormulas.push({ name: '默认大方', note: tcm.formulaHerbs != null ? tcm.formulaHerbs as string : '', smallFormulas: [{ name: '默认小方', role: '待核实', medicines: tcm.herbs }] })
      }
    }
    if (this.originalContent === '' && options != null && options.content != null) this.originalContent = options.content as string
    const firstLine = this.originalContent.split('\n')[0]
    this.recordTitle = firstLine != null && firstLine !== '' ? firstLine.substring(0, 20) : '中医整理记录'
  },
  methods: {
    goBack() { uni.navigateBack() },
    toggleOriginalRecord() { this.showOriginalRecord = !this.showOriginalRecord },
    previewReferenceImage(index: number) { if (this.referenceImages.length > 0) uni.previewImage({ current: this.referenceImages[index], urls: this.referenceImages }) },
    addReferenceImages() {
      const remain = 6 - this.referenceImages.length
      if (remain <= 0) { uni.showToast({ title: '最多保留 6 张原始资料', icon: 'none' }); return }
      uni.chooseImage({ count: remain, sizeType: ['compressed'], sourceType: ['album', 'camera'], success: (res: any) => {
        if (res != null && res.tempFilePaths != null) for (let i = 0; i < res.tempFilePaths.length && this.referenceImages.length < 6; i++) this.referenceImages.push(res.tempFilePaths[i])
      } })
    },
    removeReferenceImage(index: number) { this.referenceImages.splice(index, 1) },
    toggleFormulaStructure() { this.showFormulaStructure = !this.showFormulaStructure },
    addBigFormula() { this.bigFormulas.push({ name: '新建大方', note: '', smallFormulas: [] }) },
    removeBigFormula(index: number) { this.bigFormulas.splice(index, 1) },
    addSmallFormula(bigIndex: number) { this.bigFormulas[bigIndex].smallFormulas.push({ name: '新建小方', role: '', medicines: [] }) },
    removeSmallFormula(bigIndex: number, smallIndex: number) { this.bigFormulas[bigIndex].smallFormulas.splice(smallIndex, 1) },
    addMedicine(bigIndex: number, smallIndex: number) { this.bigFormulas[bigIndex].smallFormulas[smallIndex].medicines.push({ name: '', dose: '' }) },
    removeMedicine(bigIndex: number, smallIndex: number, medicineIndex: number) { this.bigFormulas[bigIndex].smallFormulas[smallIndex].medicines.splice(medicineIndex, 1) },
    isSharedMedicine(name: string) {
      const normalized = name.trim()
      if (normalized === '') return false
      let count = 0
      for (let i = 0; i < this.bigFormulas.length; i++) {
        const smallFormulas = this.bigFormulas[i].smallFormulas
        for (let j = 0; j < smallFormulas.length; j++) {
          const medicines = smallFormulas[j].medicines
          for (let k = 0; k < medicines.length; k++) if (medicines[k].name.trim() === normalized) { count++; break }
        }
      }
      return count > 1
    },
    smallFormulaCount() { let count = 0; for (let i = 0; i < this.bigFormulas.length; i++) count += this.bigFormulas[i].smallFormulas.length; return count },
    formulaMedicineCount() {
      let count = 0
      for (let i = 0; i < this.bigFormulas.length; i++) for (let j = 0; j < this.bigFormulas[i].smallFormulas.length; j++) count += this.bigFormulas[i].smallFormulas[j].medicines.length
      return count
    },
    sharedMedicineCount() {
      const seen = [] as string[]
      let count = 0
      for (let i = 0; i < this.bigFormulas.length; i++) {
        const smallFormulas = this.bigFormulas[i].smallFormulas
        for (let j = 0; j < smallFormulas.length; j++) for (let k = 0; k < smallFormulas[j].medicines.length; k++) {
          const name = smallFormulas[j].medicines[k].name.trim()
          if (name !== '' && seen.indexOf(name) < 0 && this.isSharedMedicine(name)) { seen.push(name); count++ }
        }
      }
      return count
    },
    formulaSummary() {
      const values = [] as string[]
      for (let i = 0; i < this.bigFormulas.length; i++) {
        const bigFormula = this.bigFormulas[i]
        const smallValues = [] as string[]
        for (let j = 0; j < bigFormula.smallFormulas.length; j++) {
          const smallFormula = bigFormula.smallFormulas[j]
          const names = [] as string[]
          for (let k = 0; k < smallFormula.medicines.length; k++) if (smallFormula.medicines[k].name.trim() !== '') names.push(smallFormula.medicines[k].name)
          if (smallFormula.name.trim() !== '' || names.length > 0) smallValues.push(smallFormula.name + '：' + names.join('、'))
        }
        if (bigFormula.name.trim() !== '' || smallValues.length > 0) values.push(bigFormula.name + '\n' + smallValues.join('\n'))
      }
      return values.join('\n\n')
    },
    addTag() { const tag = this.newTag.trim(); if (tag !== '') { this.tags.push(tag); this.newTag = '' } },
    removeTag(index: number) { this.tags.splice(index, 1) },
    onDone() {
      if (this.recordTitle.trim() === '') { uni.showToast({ title: '请填写知识标题', icon: 'none' }); return }
      const eventChannel = this.getOpenerEventChannel()
      eventChannel.emit('organizeDone', {
        draftIndex: this.draftIndex, sourceMode: this.sourceMode, archiveKey: this.archiveKey, title: this.recordTitle, dept: '中医', points: this.patternAnalysis, diagnosis: this.treatmentPrinciples,
        customFields: [{ name: '原始记录', value: this.originalContent }, { name: '四诊信息', value: this.tonguePulse }, { name: '方药结构', value: this.formulaSummary() }], tags: this.tags, referenceImages: this.referenceImages
      })
      uni.showToast({ title: '整理完成', icon: 'success' })
      setTimeout(() => { uni.navigateBack() }, 500)
    }
  }
}
</script>

<style scoped>
.tcm-header { height: 64px; padding-left: 24px; padding-right: 24px; background-color: #faf9f9; border-bottom-width: 1px; border-bottom-style: solid; border-bottom-color: #eeefee; display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.tcm-back-hit { width: 40px; height: 44px; display: flex; flex-direction: row; align-items: center; }
.tcm-back-icon { color: #1a1c1c; font-size: 28px; line-height: 32px; }
