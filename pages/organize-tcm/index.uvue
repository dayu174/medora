.formula-summary-card { margin-top: 14px; background-color: #ffffff; border-radius: 14px; border-width: 1px; border-style: solid; border-color: #d8e0de; padding: 14px 16px; display: flex; flex-direction: column; }
.formula-summary-head { display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.formula-summary-title { color: #1a1c1c; font-size: 16px; line-height: 23px; font-weight: 700; }
.formula-summary-action { color: #547774; font-size: 13px; line-height: 20px; font-weight: 600; }
.formula-summary-copy { margin-top: 5px; color: #717977; font-size: 12px; line-height: 18px; }
.formula-structure { margin-top: 12px; display: flex; flex-direction: column; }
.shared-note { border-radius: 10px; background-color: #fff5de; padding: 10px 12px; display: flex; flex-direction: column; }
.shared-note-label { color: #765922; font-size: 11px; line-height: 16px; font-weight: 700; }
.shared-note-copy { color: #6e6250; font-size: 12px; line-height: 18px; margin-top: 2px; }
.big-formula-card { margin-top: 10px; border-radius: 13px; background-color: #eaf3f1; padding: 14px; display: flex; flex-direction: column; }
.big-formula-head { display: flex; flex-direction: row; align-items: center; }
.big-formula-name { flex: 1; height: 30px; box-sizing: border-box; border-width: 0; color: #294b48; font-size: 17px; line-height: 24px; font-weight: 700; background-color: transparent; padding: 0; }
.big-formula-delete { width: 24px; color: #8a3c32; font-size: 18px; line-height: 24px; text-align: right; }
.big-formula-note { width: 100%; min-height: 38px; box-sizing: border-box; border-width: 0; color: #53615f; font-size: 12px; line-height: 19px; background-color: transparent; padding: 0; margin-top: 4px; }
.small-formula-card { margin-top: 10px; border-radius: 10px; background-color: #ffffff; border-width: 1px; border-style: solid; border-color: #d8e0de; padding: 12px; display: flex; flex-direction: column; }
.small-formula-head { display: flex; flex-direction: row; align-items: center; }
.small-formula-name { flex: 1; height: 28px; box-sizing: border-box; border-width: 0; color: #1a1c1c; font-size: 15px; line-height: 22px; font-weight: 700; background-color: transparent; padding: 0; }
.small-formula-delete { width: 24px; color: #8a3c32; font-size: 17px; line-height: 22px; text-align: right; }
.small-formula-role { width: 100%; height: 30px; box-sizing: border-box; border-width: 0; color: #717977; font-size: 12px; line-height: 18px; background-color: transparent; padding: 0; margin-top: 2px; }
.formula-medicine-row { margin-top: 8px; display: flex; flex-direction: row; align-items: center; }
