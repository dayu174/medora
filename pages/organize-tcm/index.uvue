.tcm-done { color: #547774; font-size: 15px; line-height: 24px; font-weight: 600; width: 40px; text-align: right; }
.tcm-main { padding: 18px 24px 0; display: flex; flex-direction: column; }
.original-summary { background-color: #f1f5f4; border-radius: 12px; padding: 13px 14px; display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.original-summary-copy { display: flex; flex-direction: column; }
.original-summary-title { color: #3b5e5b; font-size: 14px; line-height: 20px; font-weight: 700; }
.original-summary-meta { color: #717977; font-size: 11px; line-height: 16px; margin-top: 2px; }
.original-summary-action { color: #547774; font-size: 13px; line-height: 20px; font-weight: 600; }
.original-editor-card { background-color: #ffffff; border-radius: 12px; border-width: 1px; border-style: solid; border-color: #d8e0de; padding: 14px; margin-top: 8px; display: flex; flex-direction: column; }
.source-editor { width: 100%; min-height: 44px; box-sizing: border-box; border-width: 0; color: #414847; font-size: 13px; line-height: 21px; background-color: transparent; padding: 0; }
.reference-media-head { margin-top: 14px; display: flex; flex-direction: row; align-items: center; justify-content: space-between; }
.reference-media-title { color: #414847; font-size: 13px; line-height: 20px; font-weight: 700; }
.reference-media-add { color: #547774; font-size: 13px; line-height: 20px; font-weight: 600; }
.reference-media-scroll { width: 100%; margin-top: 8px; }
.reference-media-row { display: flex; flex-direction: row; padding-right: 8px; }
.reference-media-item { width: 76px; height: 76px; border-radius: 9px; overflow: hidden; margin-right: 8px; position: relative; background-color: #edf1f0; }
.reference-media-image { width: 76px; height: 76px; }
.reference-media-delete { position: absolute; right: 4px; top: 3px; width: 18px; height: 18px; border-radius: 9px; background-color: rgba(26, 28, 28, 0.65); color: #ffffff; font-size: 13px; line-height: 18px; text-align: center; }
.reference-media-more { width: 76px; height: 76px; border-radius: 9px; background-color: #e8f1ef; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.reference-media-more-count { color: #3b5e5b; font-size: 17px; line-height: 22px; font-weight: 700; }
.reference-media-more-copy { color: #547774; font-size: 10px; line-height: 14px; }
.reference-empty { height: 46px; margin-top: 8px; border-radius: 9px; border-width: 1px; border-style: dashed; border-color: #c1c8c6; display: flex; flex-direction: row; align-items: center; justify-content: center; }
.reference-empty-copy { color: #717977; font-size: 12px; line-height: 18px; }
.analysis-head { margin-top: 24px; margin-bottom: 10px; }
.analysis-title { color: #294b48; font-size: 23px; line-height: 32px; font-weight: 700; }
.analysis-card { background-color: #ffffff; border-radius: 14px; border-width: 1px; border-style: solid; border-color: #d8e0de; padding: 16px; display: flex; flex-direction: column; }
.field-caption { color: #717977; font-size: 12px; line-height: 18px; font-weight: 600; }
.record-title-input { width: 100%; height: 40px; box-sizing: border-box; border-width: 0; border-bottom-width: 1px; border-bottom-style: solid; border-bottom-color: #d8e0de; color: #1a1c1c; font-size: 17px; line-height: 24px; font-weight: 700; background-color: transparent; padding: 0; }
.analysis-caption { margin-top: 14px; margin-bottom: 6px; color: #547774; }
.analysis-textarea { width: 100%; min-height: 46px; box-sizing: border-box; border-width: 0; color: #1a1c1c; font-size: 15px; line-height: 23px; background-color: transparent; padding: 0; }
.four-diagnosis-card { margin-top: 12px; background-color: #ffffff; border-radius: 12px; border-width: 1px; border-style: solid; border-color: #d8e0de; padding: 14px; display: flex; flex-direction: column; }
.inspection-row { display: flex; flex-direction: row; margin-top: 9px; margin-bottom: 8px; }
.inspection-pill { padding: 6px 10px; margin-right: 6px; border-radius: 14px; background-color: #f3f5f4; border-width: 1px; border-style: solid; border-color: #d6dddb; }
.inspection-pill-active { background-color: #547774; border-color: #547774; }
.inspection-text { color: #53605e; font-size: 12px; line-height: 18px; font-weight: 600; }
.inspection-text-active { color: #ffffff; }
.four-diagnosis-textarea { width: 100%; min-height: 42px; box-sizing: border-box; border-width: 0; background-color: transparent; color: #414847; font-size: 13px; line-height: 20px; padding: 0; }
.treatment-card { margin-top: 12px; border-radius: 14px; background-color: #294b48; padding: 14px 16px; display: flex; flex-direction: column; }
.treatment-label { color: #cfe2de; font-size: 11px; line-height: 16px; font-weight: 600; margin-bottom: 4px; }
